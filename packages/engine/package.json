{
  "name": "@editx/engine",
  "version": "0.1.0-alpha.3",
  "description": "Block-based creative engine with command pattern undo/redo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amrelbialy/editx",
    "directory": "packages/engine"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./konva": {
      "types": "./dist/konva/index.d.ts",
      "import": "./dist/konva/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lexical/selection": "^0.42.0",
    "lexical": "^0.42.0"
  },
  "peerDependencies": {
    "konva": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "konva": {
      "optional": true
    }
  },
  "devDependencies": {
    "konva": "^10.0.12",
    "typescript": "^5.6.0"
  }
}
