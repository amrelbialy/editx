{
  "name": "editx",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:e2e": "turbo run test:e2e",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "release": "pnpm check && pnpm test && pnpm build && lerna version --conventional-commits --conventional-prerelease --yes",
    "release:graduate": "pnpm check && pnpm test && pnpm build && lerna version --conventional-commits --conventional-graduate --yes",
    "publish:packages": "lerna publish from-git --yes",
    "release:publish": "pnpm release && pnpm publish:packages",
    "deploy:demo": "vercel --prod"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@lerna-lite/changed": "^4.11.5",
    "@lerna-lite/cli": "^4.11.5",
    "@lerna-lite/list": "^4.11.5",
    "@lerna-lite/publish": "^4.11.5",
    "@lerna-lite/version": "^4.11.5",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.0.18",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "happy-dom": "^20.7.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=18"
  }
}
