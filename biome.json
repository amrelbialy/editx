{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "assist": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "useExhaustiveDependencies": "warn",
        "noUnusedFunctionParameters": "warn"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "useIterableCallbackReturn": "warn"
      },
      "a11y": {
        "useButtonType": "warn",
        "noNoninteractiveTabindex": "warn",
        "noStaticElementInteractions": "warn"
      }
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": false
    }
  },
  "files": {
    "includes": [
      "packages/*/src/**",
      "apps/*/src/**",
      "apps/demo/vite.config.ts",
      "apps/demo/tailwind.config.js",
      "biome.json"
    ]
  }
}
